GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Discord bot mode
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CHANNEL_ID=your_discord_channel_id_here
DISCORD_USERNAME=optional_display_name

# Optional. If omitted, the Discord worker tries to start/resolve Tailscale Funnel with the tailscale CLI.
TAILSCALE_FUNNEL_BASE_URL=https://your-mac.your-tailnet.ts.net

# Instagram Graph API publishing
INSTAGRAM_IG_USER_ID=your_instagram_ig_user_id_here
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token_here
INSTAGRAM_GRAPH_API_VERSION=v24.0
